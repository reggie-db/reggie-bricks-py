"""Metric view helpers for retrieving SQL definition text."""

import json
from typing import Any

from databricks.sdk import WorkspaceClient
from databricks.sdk.service.sql import (
    ExecuteStatementRequestOnWaitTimeout,
    StatementState,
)
from dbx_tools import clients, warehouses
from dbx_tools.catalogs import CatalogSchemaTable,CatalogSchemaTableLike
import yaml


def describe(
    name: CatalogSchemaTableLike,
    workspace_client: WorkspaceClient | None = None,
    warehouse_id: str | None = None,
    **kwargs: Any,
) -> str:
    """Return metric view YAML/SQL text from DESCRIBE TABLE EXTENDED AS JSON.

    Args:
        name: Metric view name accepted by ``CatalogSchemaTable.of``.
        workspace_client: Optional Databricks workspace client.
        warehouse_id: Optional SQL warehouse id. Uses ranked default when omitted.
        wait_timeout: Statement execution wait timeout.

    Returns:
        The ``view_text`` field from DESCRIBE TABLE EXTENDED JSON output.

    Raises:
        RuntimeError: When statement execution fails or ``view_text`` is missing.
    """
    metric_view_fqn = CatalogSchemaTable.of(name)
    if not workspace_client:
        workspace_client = clients.workspace_client()
    if not warehouse_id:
        warehouse_id = warehouses.get(workspace_client=workspace_client).id

    response = workspace_client.statement_execution.execute_statement(
        warehouse_id=warehouse_id,
        statement=f"DESCRIBE TABLE EXTENDED {metric_view_fqn} AS JSON",
        **kwargs,
    )
    state = response.status.state if response.status else None
    if state == StatementState.SUCCEEDED:
        data_array = response.result.data_array if response.result else []
        if raw_json := data_array[0][0] if data_array and data_array[0] else None:
            try:
                payload = json.loads(raw_json)
            except json.JSONDecodeError:
                payload = None
            if view_text := payload.get("view_text", None) if payload else None:
                return str(view_text)
    raise RuntimeError(
        f"Metric view '{metric_view_fqn}' describe query failed - response: {response}"
    )

def describe_data(
   *args: Any, **kwargs: Any,
) -> dict[str, Any]:
    return yaml.safe_load(describe(*args, **kwargs))


if "__main__" == __name__:
    import os

    os.environ["DATABRICKS_CONFIG_PROFILE"] = "RACETRAC-DEV"
    print(describe_data("databricks_demos.rtswv3.racetrac_kpi_metrics").get("comment"))